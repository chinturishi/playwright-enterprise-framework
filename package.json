{
  "name": "@chinturishi/playwright-enterprise-core-framework",
  "type": "module",
  "version": "1.0.2",
  "description": "Enterprise Playwright testing framework",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./fixtures": "./core/fixtures/baseFixture.js",
    "./fixtures/role": "./core/fixtures/roleFixture.js",
    "./fixtures/db": "./core/fixtures/dbFixture.js",
    "./pages": "./core/pages/BasePage.js",
    "./pages/framework": "./core/pages/FrameworkPage.js",
    "./errors": "./core/errors/FrameworkError.js",
    "./wrappers/*": "./core/wrappers/*.js",
    "./browser": "./core/browser/browserManager.js",
    "./browser/factories": "./core/browser/factories/browserFactory.js",
    "./api": "./core/api/apiInterceptor.js",
    "./config": "./config/global/configLoader.js",
    "./utils/*": "./core/utils/*.js",
    "./logging": "./core/logging/logger.js"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "clean": "node scripts/cleanReports.js",
    "merge-reports": "node scripts/mergeReports.js",
    "generate-baselines": "node scripts/generateBaseline.js",
    "summary": "node scripts/executionSummary.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "index.js",
    "core/",
    "config/",
    "integrations/",
    "templates/",
    "global-setup.js",
    "global-teardown.js"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "allure-playwright": "^3.9.0",
    "plop": "^4.0.5"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "dotenv": "^17.4.2",
    "faker": "^6.6.6",
    "fs-extra": "^11.3.5",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "winston": "^3.19.0"
  }
}
