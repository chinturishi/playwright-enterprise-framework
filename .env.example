# ==============================================================================
# playwright-enterprise-framework — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# Variables are read by configLoader and override framework.config.js defaults.
# ==============================================================================

# --- General ---
NODE_ENV=development                  # Runtime environment (development | staging | production)
LOG_LEVEL=info                        # Winston log level (error | warn | info | debug | silly)

# --- Browser ---
BROWSER=chromium                      # Default browser engine (chromium | firefox | webkit)
HEADLESS=true                         # Run browsers headless (true | false)
BASE_URL=https://example.com          # Application under test base URL

# --- Timeouts (milliseconds) ---
TIMEOUT=30000                         # Default element/action timeout
ACTION_TIMEOUT=10000                  # Timeout for individual UI actions

# --- Parallelism ---
WORKERS=4                             # Number of parallel Playwright workers
RETRIES=1                             # Failed-test retry count

# --- API ---
API_BASE_URL=https://api.example.com  # Base URL for API tests

# --- Team / project config ---
TEAM_CONFIG=                          # Path to a team-specific config file (e.g. config/teams/teamA.config.js)

# --- Jira integration ---
JIRA_BASE_URL=https://your-org.atlassian.net  # Jira instance URL
JIRA_EMAIL=                           # Jira account email for API auth
JIRA_API_TOKEN=                       # Jira API token (do NOT commit real tokens)

# --- Slack integration ---
SLACK_WEBHOOK_URL=                    # Slack incoming-webhook URL for test notifications

# --- AWS ---
AWS_REGION=us-east-1                  # AWS region for S3, Secrets Manager, CloudWatch
S3_BUCKET=                            # S3 bucket name for report uploads

# --- AI / self-healing ---
AI_ENABLED=false                      # Enable AI-assisted features (true | false)
AI_PROVIDER=openai                    # AI provider (openai | azure | anthropic)
AI_API_KEY=                           # API key for the AI provider (do NOT commit)
